{
  "name": "sobria-web",
  "version": "0.4.0",
  "private": true,
  "description": "Frontend SvelteKit pour Sobr.ia — embarqué dans Tauri (ADR-0002)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "playwright test tests/a11y",
    "e2e": "playwright test",
    "clean": "rimraf node_modules/.vite .svelte-kit build test-results playwright-report blob-report",
    "clean:full": "rimraf node_modules node_modules/.vite .svelte-kit build test-results playwright-report blob-report package-lock.json && npm install"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@sveltejs/adapter-static": "^3.0.5",
    "@sveltejs/kit": "^2.7.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/d3": "^7.4.3",
    "axe-playwright": "^2.0.3",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.0",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.7",
    "rimraf": "^6.1.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.5",
    "tslib": "^2.8.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.3"
  },
  "dependencies": {
    "@lucide/svelte": "^1.14.0",
    "@observablehq/plot": "^0.6.16",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "d3": "^7.9.0",
    "svelte-i18n": "^4.0.1"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
