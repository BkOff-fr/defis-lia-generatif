{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Capabilities par défaut de Sobr.ia — strictement minimales (voir C09 §5).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "core:webview:default",
    "core:app:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open"
  ]
}
