{
  "name": "sobria-site",
  "version": "0.1.0",
  "private": true,
  "description": "Site internet Sobr.ia — Astro 5 + Svelte 5 + Tailwind 4 (C33).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 4321",
    "start": "astro dev --port 4321",
    "build": "astro build",
    "preview": "astro preview --port 4321",
    "check": "astro check",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:a11y": "playwright test tests/a11y.spec.ts --config=tests/playwright.config.ts",
    "test:lh": "playwright test tests/lighthouse.spec.ts --config=tests/playwright.config.ts",
    "clean": "rimraf .astro dist node_modules/.vite"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "@astrojs/svelte": "^7.0.0",
    "@lucide/svelte": "^1.14.0",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.0.0",
    "motion": "^11.11.0",
    "pagefind": "^1.1.1",
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "three": "~0.170.0",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/three": "~0.170.0",
    "axe-playwright": "^2.0.3",
    "eslint": "^9.13.0",
    "eslint-plugin-astro": "^1.3.0",
    "eslint-plugin-svelte": "^2.46.0",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.2.7",
    "rimraf": "^6.1.3",
    "typescript-eslint": "^8.10.0"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
