---
import SearchBar from '$components/docs/SearchBar.svelte';

const navItems = [
  { href: '/produit/', label: 'Produit' },
  { href: '/equipe/', label: 'Équipe' },
  { href: '/methode/', label: 'Méthode' },
  { href: '/docs/', label: 'Docs' },
];
const githubUrl = 'https://github.com/BkOff-fr/defis-lia-generatif';
const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || currentPath === href.replace(/\/$/, '');
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-ink/80 border-b border-ivory-4/30">
  <nav
    class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between gap-4"
    aria-label="Navigation principale"
  >
    <a href="/" class="flex items-center gap-2 font-display text-xl">
      <span class="text-lime-signature italic">s</span>
      <span class="text-ivory">Sobr.ia</span>
    </a>

    <ul class="hidden md:flex items-center gap-6 text-sm">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class={
                isActive(item.href)
                  ? 'text-lime-signature'
                  : 'text-ivory-2 hover:text-ivory transition-colors'
              }
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <SearchBar client:load />
      <a
        href={githubUrl}
        rel="noopener external"
        class="text-sm text-ivory-2 hover:text-ivory transition-colors hidden lg:inline-flex"
      >
        GitHub
      </a>
      <a
        href="/telecharger/"
        class="text-sm bg-lime-signature text-ink font-medium rounded-md px-3 py-1.5 hover:bg-lime-deep transition-colors hidden sm:inline-flex"
      >
        Télécharger
      </a>
    </div>
  </nav>
</header>
