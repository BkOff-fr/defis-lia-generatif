---
const year = new Date().getFullYear();
const githubUrl = 'https://github.com/BkOff-fr/defis-lia-generatif';

const produit = [
  { href: '/', label: 'Présentation' },
  { href: '/manifeste/', label: 'Le manifeste' },
  { href: '/produit/', label: 'Produit' },
  { href: '/equipe/', label: 'Équipe' },
  { href: '/methode/', label: 'Méthode' },
  { href: '/telecharger/', label: 'Télécharger' },
];

const ressources = [
  { href: '/docs/', label: 'Docs' },
  { href: '/candidature/', label: 'Candidature data.gouv.fr' },
  { href: '/adrs/', label: 'ADRs' },
];

const communaute = [
  { href: githubUrl, label: 'GitHub', external: true },
  { href: `${githubUrl}/issues`, label: 'Signaler un problème', external: true },
  { href: `${githubUrl}/releases`, label: 'Releases', external: true },
];

const adrs = [
  { id: '0009', label: 'Architecture médaillon', href: '/adrs/adr-0009-medallion-architecture/' },
  { id: '0012', label: 'Multi-méthodologie', href: '/adrs/adr-0012-multi-methodology-engine/' },
  {
    id: '0013',
    label: 'Pairing équipe',
    href: '/adrs/adr-0013-extension-pairing-team-mode/',
  },
  {
    id: '0015',
    label: 'Privacy Mode Équipe',
    href: '/adrs/adr-0015-privacy-mode-equipe/',
  },
];
---

<footer class="border-t border-ivory-4/30 mt-24 text-sm text-ivory-3">
  <div class="max-w-6xl mx-auto px-6 py-12 grid gap-10 md:grid-cols-4">
    <div>
      <p class="font-display text-2xl text-ivory">
        <span class="text-lime-signature italic">s</span>obr.ia
      </p>
      <p class="mt-3">L'impact environnemental de l'IA générative, mesuré.</p>
      <p class="mt-4">
        <a
          href="/candidature/"
          class="inline-flex items-center gap-2 rounded-full border border-lime-signature/40 text-lime-signature px-3 py-1 text-xs font-sans hover:bg-lime-signature/10 transition-colors"
        >
          🏛 Candidat data.gouv.fr
        </a>
      </p>
    </div>

    <div>
      <h3 class="text-ivory text-base mb-3 font-sans">Produit</h3>
      <ul class="space-y-1.5">
        {
          produit.map((item) => (
            <li>
              <a href={item.href} class="hover:text-ivory">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="text-ivory text-base mb-3 font-sans">Ressources</h3>
      <ul class="space-y-1.5">
        {
          ressources.map((item) => (
            <li>
              <a href={item.href} class="hover:text-ivory">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3 class="text-ivory text-base mb-3 font-sans">Communauté</h3>
      <ul class="space-y-1.5">
        {
          communaute.map((item) => (
            <li>
              <a
                href={item.href}
                rel={item.external ? 'noopener external' : undefined}
                class="hover:text-ivory"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-ivory-4/30 max-w-6xl mx-auto px-6 py-6">
    <p class="text-xs text-ivory-3 mb-2">Décisions architecture (ADRs) :</p>
    <ul class="flex flex-wrap gap-2">
      {
        adrs.map((a) => (
          <li>
            <a
              href={a.href}
              class="inline-flex items-center gap-1.5 rounded-full border border-ivory-4/40 px-2.5 py-0.5 text-xs hover:border-lime-signature/40 hover:text-ivory transition-colors"
            >
              <span class="font-mono text-ivory-3">ADR-{a.id}</span>
              <span>{a.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="border-t border-ivory-4/30 text-xs text-center py-4 px-6">
    &copy; {year} — Sobr.ia · Code MIT · Docs CC-BY 4.0 · Datasets Etalab 2.0 · Candidature défi data.gouv.fr
    « Impact environnemental de l'IA générative »
  </div>
</footer>
