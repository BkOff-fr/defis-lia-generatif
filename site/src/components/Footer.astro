---
const year = new Date().getFullYear();
---

<footer class="border-t border-ivory-4/30 mt-24 text-sm text-ivory-3">
  <div class="max-w-6xl mx-auto px-6 py-12 grid gap-10 md:grid-cols-4">
    <div>
      <p class="font-display text-2xl text-ivory">
        <span class="text-lime-signature italic">s</span>obr.ia
      </p>
      <p class="mt-3">L'impact environnemental de l'IA générative, mesuré.</p>
    </div>

    <div>
      <h3 class="text-ivory text-base mb-3 font-sans">Produit</h3>
      <ul class="space-y-1.5">
        <li><a href="/#download" class="hover:text-ivory">Télécharger</a></li>
        <li><a href="/telecharger/" class="hover:text-ivory">Versions</a></li>
        <li><a href="/cloud/" class="hover:text-ivory">Mode Équipe / Cloud</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-ivory text-base mb-3 font-sans">Documentation</h3>
      <ul class="space-y-1.5">
        <li><a href="/docs/" class="hover:text-ivory">Guide</a></li>
        <li><a href="/adrs/" class="hover:text-ivory">ADRs</a></li>
