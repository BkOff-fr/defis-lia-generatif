---
// /cloud → /equipe : le contenu « Mode Équipe & Cloud » vit désormais sur
// /equipe (l'offre cloud managée y reste mentionnée — à l'étude, ADR-0014).
// Redirection meta refresh (site statique) + lien de secours.
import '$styles/global.css';

const target = '/equipe/';
const canonical = new URL(target, Astro.site).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Redirection — Mode Équipe Sobr.ia</title>
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0a0d0b" />
  </head>
  <body class="bg-ink text-ivory">
    <main class="min-h-screen flex items-center justify-center px-6">
      <p class="text-center text-ivory-2">
        Cette page a déménagé.
        <a href={target} class="text-lime-signature underline underline-offset-4"
          >Continuer vers le Mode Équipe</a
        >
      </p>
    </main>
  </body>
</html>
