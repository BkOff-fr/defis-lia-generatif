        color: var(--ivory-3);
      }
      .dc-row b {
        color: var(--ivory);
        font-family: var(--mono);
        font-weight: 500;
      }
      .dc-op {
        margin-top: 10px;
        font: 400 10px var(--mono);
        color: var(--ivory-4);
