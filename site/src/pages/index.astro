              <div class="tb-row">
                <span class="tb-av">MN</span><span class="tb-nm">Marie N.</span><span class="tb-bar"
                  ><i style="--w:58%"></i></span
                ><span class="tb-val">298<small>g</small></span>
              </div>
              <div class="tb-row">
                <span class="tb-av">PT</span><span class="tb-nm">Paul T.</span><span class="tb-bar"
                  ><i style="--w:44%"></i></span
                ><span class="tb-val">221<small>g</small></span>
              </div>
              <div class="tb-row">
                <span class="tb-av">SR</span><span class="tb-nm">Sara R.</span><span class="tb-bar"
                  ><i style="--w:29%"></i></span
                ><span class="tb-val">146<small>g</small></span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="chap ch-3" data-chap="3">
        <div class="inner">
          <div class="usage-panel rise">
            <div class="up-head">
              <div>
                <div class="up-title">Cette semaine · objectif <b>50 g/jour</b></div>
