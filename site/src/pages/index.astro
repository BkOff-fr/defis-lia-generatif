        background: linear-gradient(180deg, #c5f04a, #7a9a32);
        border-radius: 4px;
        height: var(--h);
        min-height: 6px;
        transition: background 200ms;
      }
      .up-day.over i {
        background: linear-gradient(180deg, #f08c5a, #9a4d2a);
      }
      .up-day.on i {
        box-shadow: 0 0 16px rgba(197, 240, 74, 0.4);
      }
      .up-day .up-l {
        font: 500 10px var(--mono);
        color: var(--ivory-3);
        margin-top: 6px;
