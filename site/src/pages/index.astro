      }
      .up-alerts input[type='checkbox'] {
        accent-color: var(--lime);
        width: 14px;
        height: 14px;
      }

      /* ─── ch-4 datacenters ─── */
      .dc-map {
        display: grid;
        grid-template-columns: 1fr 240px;
        gap: 16px;
        align-items: start;
        background: linear-gradient(160deg, rgba(15, 18, 16, 0.88), rgba(15, 18, 16, 0.55));
        backdrop-filter: blur(20px);
