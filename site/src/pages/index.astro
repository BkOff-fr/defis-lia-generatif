    <!-- Three.js 0.158.0 self-hosted : la CSP nginx restreint script-src
         a 'self' (cf. .well-known config), donc unpkg.com etait bloque
         et toute la JS d'animation tombait avant l'IntersectionObserver. -->
    <script is:inline src="/lib/three-0.158.0.min.js"></script>
    <script is:inline>
      /* ════════════════════════════════════════════════════════
         THREE.JS — token swarm + per-chapter environments
         (terrainMat + metaballs refs from original handoff removed:
         dead code that would have thrown ReferenceError)
         ════════════════════════════════════════════════════════ */
      const canvas = document.getElementById('webgl');
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(50, innerWidth / innerHeight, 0.1, 200);
      camera.position.set(0, 0, 12);

      function resize() {
        renderer.setSize(innerWidth, innerHeight, false);
        camera.aspect = innerWidth / innerHeight;
        camera.updateProjectionMatrix();
      }
      resize();
      addEventListener('resize', resize);

      const mouse = { x: 0, y: 0, mx: 0, my: 0 };
      addEventListener('mousemove', (e) => {
        mouse.x = (e.clientX / innerWidth) * 2 - 1;
        mouse.y = -(e.clientY / innerHeight) * 2 + 1;
        mouse.mx = e.clientX;
        mouse.my = e.clientY;
      });
      const isMobile = innerWidth < 900;

      let orbPulse = 0;
      addEventListener('click', () => {
        if (scrollY < innerHeight * 0.8) orbPulse = 1.0;
      });

      /* ─── Hero abstract sphere (ch 0 focal) ─── */
      const heroOrb = new THREE.Group();
      const orbWire = new THREE.LineSegments(
        new THREE.WireframeGeometry(new THREE.IcosahedronGeometry(2.6, 1)),
        new THREE.LineBasicMaterial({ color: 0xc5f04a, transparent: true, opacity: 0 }),
      );
      const orbInner = new THREE.Mesh(
        new THREE.IcosahedronGeometry(2.6, 1),
        new THREE.MeshBasicMaterial({
          color: 0xc5f04a,
          transparent: true,
          opacity: 0,
          wireframe: false,
          side: THREE.BackSide,
        }),
      );
      heroOrb.add(orbInner);
      heroOrb.add(orbWire);
      scene.add(heroOrb);

      /* ─── Token swarm ─── */
      const TOKEN_WORDS = [
        'prompt',
        'tokens',
        'GPU',
        'PUE',
        'Wh',
        'CO₂eq',
        '2,14 g',
        'compute',
        'context',
        'live',
        'local',
        'sobr.ia',
        'open',
        'audit',
        'équipe',
        'budget',
        'impact',
        'carbone',
        'énergie',
        'kWh',
        'voiture',
        'douche',
        'forêt',
        'Paris',
        'Frankfurt',
        'Mistral',
        'GPT-5',
        'Claude',
        'datacenter',
        'cloud',
        'green',
        'watt',
        'reply',
        'sobre',
        'frugal',
        'batch',
        'warm',
        'cool',
        'idle',
      ];

      function makeTokenTex(word, color, weight) {
        const c = document.createElement('canvas');
        c.width = 384;
        c.height = 96;
        const ctx = c.getContext('2d');
        ctx.font =
          (weight === 'bold' ? '600 ' : '') + 'italic 52px "Instrument Serif",Georgia,serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillStyle = color;
        ctx.shadowColor = color;
        ctx.shadowBlur = 16;
        ctx.fillText(word, 192, 48);
        return new THREE.CanvasTexture(c);
      }

      const tokens = [];
      const star = new THREE.Group();
      scene.add(star);
      const PALETTE = ['#c5f04a', '#f0ece3', '#b8b4ac', '#72706a'];
      TOKEN_WORDS.forEach((word, idx) => {
        const isAccent = idx % 5 === 0;
        const tex = makeTokenTex(
          word,
          isAccent ? '#c5f04a' : PALETTE[idx % PALETTE.length],
          isAccent ? 'bold' : '',
        );
        const sprite = new THREE.Sprite(
          new THREE.SpriteMaterial({
            map: tex,
            transparent: true,
            depthWrite: false,
            opacity: 0.85,
            blending: THREE.NormalBlending,
          }),
        );
        sprite.scale.set(2.4, 0.6, 1);
        sprite.userData = { seed: Math.random() * Math.PI * 2, targets: [], word, isAccent };
        star.add(sprite);
        tokens.push(sprite);
      });

      function rand(a, b) {
        return a + Math.random() * (b - a);
      }
      tokens.forEach((tok, i) => {
        const T = [];
        T[0] = new THREE.Vector3(rand(-12, 12), rand(-7, 7), rand(-6, 4));
        const a1 = (i / tokens.length) * Math.PI * 2;
        T[1] = new THREE.Vector3(
          -5 + Math.cos(a1) * 2.8,
          Math.sin(a1) * 2.2,
          Math.sin(a1 * 2) * 1.5,
        );
        const team = i % 5;
        T[2] = new THREE.Vector3(
          (team - 2) * 2.6 + rand(-0.8, 0.8),
          rand(-2.2, 2.2) - 1,
          rand(-1, 1),
        );
        const t3 = i / tokens.length;
        T[3] = new THREE.Vector3(
          -9 + t3 * 18,
          Math.sin(t3 * Math.PI * 3) * 1.8 - 1,
          rand(-1.5, 1.5),
        );
        const dc = [
          [-4, 1.5],
          [2.5, 2],
          [-3, -1],
          [1, -0.5],
          [3.5, -2],
          [0, 2.5],
          [-1, 1],
          [2, -2.5],
          [-2, 2.8],
        ];
        const p4 = dc[i % dc.length];
        T[4] = new THREE.Vector3(p4[0] + rand(-0.6, 0.6), p4[1] + rand(-0.6, 0.6), rand(-0.8, 0.8));
        T[5] = new THREE.Vector3(-5 + rand(-1.4, 1.4), (i / tokens.length - 0.5) * 10, rand(-1, 1));
        const a6 = (i / tokens.length) * Math.PI * 2;
        const r6 = 6 + Math.random() * 3;
        T[6] = new THREE.Vector3(Math.cos(a6) * r6, Math.sin(a6) * r6, rand(-4, 4));
        tok.userData.targets = T;
        tok.position.copy(T[0]);
      });

      /* ─── Particles (background swarm) ─── */
      const PCOUNT = innerWidth < 700 ? 600 : 1400;
      const ppos = new Float32Array(PCOUNT * 3);
      const psize = new Float32Array(PCOUNT);
      const pseed = new Float32Array(PCOUNT);
      for (let i = 0; i < PCOUNT; i++) {
        ppos[3 * i] = (Math.random() - 0.5) * 30;
        ppos[3 * i + 1] = (Math.random() - 0.5) * 20;
        ppos[3 * i + 2] = (Math.random() - 0.5) * 15 - 5;
        psize[i] = Math.random() * 0.08 + 0.02;
        pseed[i] = Math.random() * Math.PI * 2;
      }
      const pgeo = new THREE.BufferGeometry();
      pgeo.setAttribute('position', new THREE.BufferAttribute(ppos, 3));
      pgeo.setAttribute('size', new THREE.BufferAttribute(psize, 1));
      pgeo.setAttribute('seed', new THREE.BufferAttribute(pseed, 1));
      const pmat = new THREE.ShaderMaterial({
        transparent: true,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
        uniforms: { uTime: { value: 0 }, uMult: { value: 1 } },
        vertexShader:
          'attribute float size;attribute float seed;uniform float uTime;uniform float uMult;varying float vA;void main(){vec3 p=position;p.x+=sin(uTime*.3+seed)*.2;p.y+=cos(uTime*.4+seed*1.3)*.2;p.y+=uTime*.05*uMult;p.y=mod(p.y+10.,20.)-10.;vec4 mv=modelViewMatrix*vec4(p,1.);gl_Position=projectionMatrix*mv;gl_PointSize=size*uMult*(300./-mv.z);vA=.7;}',
        fragmentShader:
          'varying float vA;void main(){vec2 c=gl_PointCoord-.5;float d=length(c);if(d>.5)discard;float f=pow(1.-d*2.,2.);gl_FragColor=vec4(.77,.94,.29,f*vA);}',
      });
      const particles = new THREE.Points(pgeo, pmat);
      scene.add(particles);

      /* ─── Fog plane (ch 1) ─── */
      const fogPlane = new THREE.Mesh(
        new THREE.PlaneGeometry(40, 24),
        new THREE.ShaderMaterial({
          transparent: true,
          depthWrite: false,
          uniforms: {
            uTime: { value: 0 },
            uAlpha: { value: 0 },
            uMouse: { value: new THREE.Vector2() },
          },
          vertexShader:
            'varying vec2 vUv;void main(){vUv=uv;gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.);}',
          fragmentShader:
            'varying vec2 vUv;uniform float uTime;uniform float uAlpha;uniform vec2 uMouse;float h(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}float n(vec2 p){vec2 i=floor(p),f=fract(p);float a=h(i),b=h(i+vec2(1.,0.)),c=h(i+vec2(0.,1.)),d=h(i+vec2(1.,1.));vec2 u=f*f*(3.-2.*f);return mix(a,b,u.x)+(c-a)*u.y*(1.-u.x)+(d-b)*u.x*u.y;}void main(){vec2 p=vUv*3.+uTime*.04;float v=n(p)*.5+n(p*2.)*.25+n(p*4.)*.125;float d=distance(vUv,vec2(.5,.5)+uMouse*.2);float spot=smoothstep(.3,0.,d);gl_FragColor=vec4(vec3(.77,.94,.29)*v*.6+vec3(.49,.6,.18)*spot*.8,(v*.4+spot*.6)*uAlpha);}',
        }),
      );
      fogPlane.position.set(0, 0, -3);
      scene.add(fogPlane);

      /* ─── Leaf path ─── */
      function svgToScene(x, y, scale = 0.08) {
        return new THREE.Vector3((x - 50) * scale, (50 - y) * scale, 0);
      }
      const leafCurve = new THREE.CatmullRomCurve3(
        [
          svgToScene(18, 78),
          svgToScene(15, 64),
          svgToScene(20, 46),
          svgToScene(36, 28),
          svgToScene(58, 22),
          svgToScene(76, 28),
          svgToScene(85, 44),
          svgToScene(83, 60),
          svgToScene(70, 78),
          svgToScene(48, 86),
          svgToScene(28, 86),
          svgToScene(18, 78),
        ],
        true,
        'catmullrom',
        0.5,
      );

      const LOGO_NODES = [
        { pos: svgToScene(32, 72), r: 0.22 },
        { pos: svgToScene(50, 52), r: 0.3 },
        { pos: svgToScene(74, 32), r: 0.2 },
      ];

      /* ─── Ch 2 — path-build particles ─── */
      const PATH_PARTS = 90;
      const pathParticles = new THREE.Group();
      for (let i = 0; i < PATH_PARTS; i++) {
        const m = new THREE.Mesh(
          new THREE.SphereGeometry(0.045, 8, 8),
          new THREE.MeshBasicMaterial({ color: 0xc5f04a, transparent: true, opacity: 0 }),
        );
        m.userData = {
          u: i / PATH_PARTS,
          scatter: new THREE.Vector3(
            (Math.random() - 0.5) * 9,
            (Math.random() - 0.5) * 6,
            (Math.random() - 0.5) * 5,
          ),
          seed: Math.random() * Math.PI * 2,
        };
        pathParticles.add(m);
      }
      pathParticles.scale.setScalar(8);
      scene.add(pathParticles);

      const pathLineGeo = new THREE.BufferGeometry().setFromPoints(leafCurve.getPoints(200));
      const pathLine = new THREE.Line(
        pathLineGeo,
        new THREE.LineBasicMaterial({ color: 0xc5f04a, transparent: true, opacity: 0 }),
      );
      pathLine.scale.setScalar(8);
      scene.add(pathLine);

      /* ─── Ch 3 — full logo ─── */
      const logoGroup = new THREE.Group();
      const logoTube = new THREE.Mesh(
        new THREE.TubeGeometry(leafCurve, 200, 0.07, 8, true),
        new THREE.MeshBasicMaterial({ color: 0xc5f04a, transparent: true, opacity: 0 }),
      );
      logoTube.scale.setScalar(8);
      logoGroup.add(logoTube);
      const logoNodes = LOGO_NODES.map((n) => {
        const s = new THREE.Mesh(
          new THREE.SphereGeometry(n.r, 24, 24),
          new THREE.MeshBasicMaterial({ color: 0xc5f04a, transparent: true, opacity: 0 }),
        );
        s.position.copy(n.pos).multiplyScalar(8);
        const halo = new THREE.Mesh(
          new THREE.SphereGeometry(n.r * 1.8, 16, 16),
          new THREE.MeshBasicMaterial({
            color: 0xc5f04a,
            transparent: true,
            opacity: 0,
            blending: THREE.AdditiveBlending,
            depthWrite: false,
          }),
        );
        halo.position.copy(s.position);
        s.userData.halo = halo;
        logoGroup.add(s);
        logoGroup.add(halo);
        return s;
      });
      scene.add(logoGroup);

      /* ─── Ch 6 — globe ─── */
      const earth = new THREE.Group();
      const earthCore = new THREE.Mesh(
        new THREE.SphereGeometry(3.2, 32, 24),
        new THREE.MeshBasicMaterial({ color: 0x0a0d0b, transparent: true, opacity: 0 }),
      );
      const earthWire = new THREE.LineSegments(
        new THREE.WireframeGeometry(new THREE.SphereGeometry(3.2, 22, 16)),
        new THREE.LineBasicMaterial({ color: 0xc5f04a, transparent: true, opacity: 0 }),
      );
      earth.add(earthCore);
      earth.add(earthWire);
      const earthDots = [];
      for (let i = 0; i < 14; i++) {
        const phi = Math.acos(1 - 2 * ((i + 0.5) / 14));
        const theta = Math.PI * (1 + Math.sqrt(5)) * i;
        const R = 3.25;
        const d = new THREE.Mesh(
          new THREE.SphereGeometry(0.1, 12, 12),
          new THREE.MeshBasicMaterial({ color: 0xc5f04a, transparent: true, opacity: 0 }),
        );
        d.position.set(
          R * Math.sin(phi) * Math.cos(theta),
          R * Math.cos(phi),
          R * Math.sin(phi) * Math.sin(theta),
        );
        earth.add(d);
        earthDots.push(d);
      }
      scene.add(earth);

      /* ─── Camera + state per chapter ─── */
      const CHAPTERS = [
        {
          pos: [0, 0, 12],
          look: [0, 0, 0],
          starScale: 1.0,
          starOffsetX: 0,
          starRotSpeed: 0.25,
          chromShift: 0.05,
          mode: 'star',
        },
        {
          pos: [3, 0, 10],
          look: [-0.5, 0, 0],
          starScale: 0.85,
          starOffsetX: -3.5,
          starRotSpeed: 0.35,
          chromShift: 0.1,
          mode: 'fog',
        },
        {
          pos: [0, 3, 15],
          look: [0, -2, 0],
          starScale: 0.7,
          starOffsetX: 0,
          starRotSpeed: 0.5,
          chromShift: 0.08,
          mode: 'terrain',
        },
        {
          pos: [0, 0, 11],
          look: [0, 0, 0],
          starScale: 0.9,
          starOffsetX: 0,
          starRotSpeed: 0.15,
          chromShift: 0.2,
          mode: 'tension',
        },
        {
          pos: [0, 0, 9],
          look: [0, 0, 0],
          starScale: 1.4,
          starOffsetX: 0,
          starRotSpeed: 0.2,
          chromShift: 0.04,
          mode: 'leaf',
        },
        {
          pos: [3, -1, 10],
          look: [-2, 0, 0],
          starScale: 0.4,
          starOffsetX: 4.5,
          starRotSpeed: 0.6,
          chromShift: 0.06,
          mode: 'small',
        },
        {
          pos: [0, 0, 12],
          look: [0, 0, 0],
          starScale: 0.9,
          starOffsetX: 0,
          starRotSpeed: 0.18,
          chromShift: 0.04,
          mode: 'globe',
        },
      ];

      /* ─── Scroll progress ─── */
      const chaps = document.querySelectorAll('.chap');
      const dots = document.querySelectorAll('.rail .dot');
      let progress = 0;
      function computeProgress() {
        const sy = scrollY,
          vh = innerHeight;
        for (let i = 0; i < chaps.length; i++) {
          const top = chaps[i].offsetTop;
          const next = i < chaps.length - 1 ? chaps[i + 1].offsetTop : top + chaps[i].offsetHeight;
          if (sy + vh * 0.5 >= top && sy + vh * 0.5 < next)
            return i + Math.min(1, (sy + vh * 0.5 - top) / (next - top));
          if (i === chaps.length - 1 && sy + vh * 0.5 >= top) return chaps.length - 1;
        }
        return 0;
      }
      function smoothstep(x) {
        return x * x * (3 - 2 * x);
      }
      let easedP = 0;
      function onScroll() {
        progress = computeProgress();
        const docH = document.documentElement.scrollHeight - innerHeight;
        document.getElementById('progress').style.width =
          Math.min(100, Math.max(0, (scrollY / docH) * 100)) + '%';
        const idx = Math.round(progress);
        dots.forEach((d) => d.classList.toggle('on', +d.dataset.i === idx));
        document.getElementById('cue').classList.toggle('gone', scrollY > innerHeight * 0.4);
      }
      addEventListener('scroll', onScroll, { passive: true });
      onScroll();
      dots.forEach((d) =>
        d.addEventListener('click', () => {
          const t = chaps[+d.dataset.i];
          if (t) scrollTo({ top: t.offsetTop + 1, behavior: 'smooth' });
        }),
      );

      /* ─── Animation loop ─── */
      let last = performance.now();
      const tmpV = new THREE.Vector3();
      const tmpLook = new THREE.Vector3();

      function loop(now) {
        const dt = (now - last) / 1000;
        last = now;
        const targetP = progress;
        easedP += (targetP - easedP) * Math.min(1, dt * 5);
        const t = easedP;
        pmat.uniforms.uTime.value += dt;
        fogPlane.material.uniforms.uTime.value += dt;

        const i0 = Math.max(0, Math.min(6, Math.floor(t))),
          i1 = Math.max(0, Math.min(6, i0 + 1));
        const f = t - i0,
          fe = smoothstep(Math.min(1, Math.max(0, f)));
        const c0 = CHAPTERS[i0],
          c1 = CHAPTERS[i1];

        const px = c0.pos[0] + (c1.pos[0] - c0.pos[0]) * fe;
        const py = c0.pos[1] + (c1.pos[1] - c0.pos[1]) * fe;
        const pz = c0.pos[2] + (c1.pos[2] - c0.pos[2]) * fe;
        const mobZ = isMobile ? 6 : 0;
        tmpV.set(
          px + mouse.x * (isMobile ? 0.2 : 0.6),
          py + mouse.y * (isMobile ? 0.15 : 0.4),
          pz + mobZ,
        );
        camera.position.lerp(tmpV, 0.06);
        tmpLook.set(
          c0.look[0] + (c1.look[0] - c0.look[0]) * fe,
          c0.look[1] + (c1.look[1] - c0.look[1]) * fe,
          c0.look[2] + (c1.look[2] - c0.look[2]) * fe,
        );
        camera.lookAt(tmpLook);

        const offX = c0.starOffsetX + (c1.starOffsetX - c0.starOffsetX) * fe;
        const scale = c0.starScale + (c1.starScale - c0.starScale) * fe;
        star.position.set(offX, 0, 0);
        star.scale.setScalar(scale);
        tokens.forEach((tok) => {
          const T = tok.userData.targets;
          const a = T[i0],
            b = T[i1];
          const tx = a.x + (b.x - a.x) * fe;
          const ty = a.y + (b.y - a.y) * fe;
          const tz = a.z + (b.z - a.z) * fe;
          tok.position.x += (tx - tok.position.x) * 0.07;
          tok.position.y += (ty - tok.position.y) * 0.07;
          tok.position.z += (tz - tok.position.z) * 0.07;
          tok.position.y += Math.sin(pmat.uniforms.uTime.value * 0.5 + tok.userData.seed) * 0.003;
          tok.position.x +=
            Math.cos(pmat.uniforms.uTime.value * 0.4 + tok.userData.seed * 1.3) * 0.002;
          if (tok.userData.isAccent) {
            const dx = mouse.x * 6 - tok.position.x;
            const dy = mouse.y * 4 - tok.position.y;
            const d2 = dx * dx + dy * dy;
            if (d2 < 9) {
              const k = (1 - Math.sqrt(d2) / 3) * 0.06;
              tok.position.x += dx * k;
              tok.position.y += dy * k;
            }
            tok.position.x += mouse.x * 0.08;
            tok.position.y += mouse.y * 0.06;
          }
          const tokenVis = t < 4.2 ? 0 : Math.min(1, (t - 4.2) * 1.6);
          tok.material.opacity = tokenVis * (0.55 + (1 - Math.abs(f - 0.5) * 2) * 0.35);
        });

        if (orbPulse > 0.01) orbPulse *= 0.94;
        const orbA = t < 0.85 ? 1 - t * 1.18 : 0;
        heroOrb.visible = orbA > 0.01;
        if (heroOrb.visible) {
          heroOrb.rotation.y += dt * 0.18;
          heroOrb.rotation.x = Math.sin(pmat.uniforms.uTime.value * 0.25) * 0.2;
          const baseScale = 0.95 + Math.sin(pmat.uniforms.uTime.value * 0.8) * 0.04;
          heroOrb.scale.setScalar(baseScale + orbPulse * 0.4);
          orbWire.material.opacity = orbA * (0.75 + orbPulse * 0.5);
          orbInner.material.opacity = orbA * (0.06 + orbPulse * 0.15);
        }

        const fogA = t >= 0.5 && t < 1.7 ? Math.min(1, 1 - Math.abs(t - 1) * 1.0) : 0;
        fogPlane.material.uniforms.uAlpha.value = fogA;
        fogPlane.material.uniforms.uMouse.value.set(mouse.x * 0.4, mouse.y * 0.4);

        const ch2A = t >= 1.4 && t < 2.7 ? Math.min(1, 1 - Math.abs(t - 2) * 1.0) : 0;
        const buildP = Math.max(0, Math.min(1, (t - 1.0) * 1.0));
        const buildE = smoothstep(buildP);
        pathParticles.visible = ch2A > 0.01 || (t > 0.8 && t < 3.2);
        if (pathParticles.visible) {
          pathParticles.rotation.y = Math.sin(pmat.uniforms.uTime.value * 0.15) * 0.1;
          pathParticles.children.forEach((p) => {
            const u = (p.userData.u + pmat.uniforms.uTime.value * 0.02) % 1;
            const tgt = leafCurve.getPoint(u);
            p.position.x = p.userData.scatter.x + (tgt.x * 8 - p.userData.scatter.x) * buildE;
            p.position.y = p.userData.scatter.y + (tgt.y * 8 - p.userData.scatter.y) * buildE;
            p.position.z = p.userData.scatter.z + (tgt.z * 8 - p.userData.scatter.z) * buildE;
            p.position.y += Math.sin(pmat.uniforms.uTime.value * 0.8 + p.userData.seed) * 0.04;
            p.material.opacity = Math.max(ch2A * 0.95, buildE * 0.7);
          });
          pathLine.material.opacity = Math.max(0, (buildE - 0.5) * 2) * 0.55 * Math.max(0.3, ch2A);
        }

        const logoA = t >= 2.3 && t < 3.8 ? Math.min(1, 1 - Math.abs(t - 3) * 0.95) : 0;
        logoGroup.visible = logoA > 0.01;
        if (logoGroup.visible) {
          logoGroup.rotation.y = pmat.uniforms.uTime.value * 0.18;
          logoGroup.rotation.z = Math.sin(pmat.uniforms.uTime.value * 0.12) * 0.06;
          logoTube.material.opacity = logoA * 0.95;
          logoNodes.forEach((n, idx) => {
            n.material.opacity = logoA;
            const pulse = 1 + Math.sin(pmat.uniforms.uTime.value * 1.6 + idx * 1.2) * 0.15;
            n.scale.setScalar(pulse);
            n.userData.halo.material.opacity =
              logoA * 0.35 * (0.6 + Math.sin(pmat.uniforms.uTime.value * 2 + idx) * 0.4);
            n.userData.halo.scale.setScalar(pulse * 1.2);
          });
        }

        const earthA = t >= 5.4 ? Math.min(1, (t - 5.4) * 2) : 0;
        earth.visible = earthA > 0.01;
        if (earth.visible) {
          earth.rotation.y += dt * 0.18;
          earth.rotation.x = 0.2;
          earthCore.material.opacity = 0.7 * earthA;
          earthWire.material.opacity = 0.4 * earthA;
          earthDots.forEach((d, i) => {
            d.material.opacity =
              (0.7 + Math.sin(pmat.uniforms.uTime.value * 1.4 + i * 0.5) * 0.3) * earthA;
          });
        }

        pmat.uniforms.uMult.value = 1 + (window.__multiVal || 0) * 4;

        renderer.render(scene, camera);
        requestAnimationFrame(loop);
      }
      requestAnimationFrame(loop);

      /* ════════════════════════════════════════════════════════
         INTERACTIVE DEMOS
         ════════════════════════════════════════════════════════ */

      /* Ch 1 — Live CO2 calculator */
      const MODELS = {
        gpt5: { whIn: 0.0042, whOut: 0.014, pue: 1.28, mix: 392, name: 'GPT-5' },
        claude4: { whIn: 0.0038, whOut: 0.013, pue: 1.3, mix: 268, name: 'Claude 4' },
        mistralL: { whIn: 0.0034, whOut: 0.011, pue: 1.18, mix: 56, name: 'Mistral Large' },
        gpt4mini: { whIn: 0.0015, whOut: 0.005, pue: 1.28, mix: 392, name: 'GPT-4o-mini' },
      };
      function fmt(v, d = 2) {
        return v.toFixed(d).replace('.', ',');
      }
      function calcLive() {
        const txt = document.getElementById('liveInput').value;
        const modelKey = document.getElementById('liveModel').value;
        const m = MODELS[modelKey];
        const tokIn = Math.max(1, Math.round(txt.length / 3.2));
        const tokOut = Math.max(20, Math.round(tokIn * 3.5));
        const wh = (tokIn * m.whIn + tokOut * m.whOut) * m.pue;
        const co2g = wh * (m.mix / 1000);
        const water = wh * 1.8;
        const kmCar = co2g / 0.192;
        document.getElementById('liveTokens').textContent = '~ ' + tokIn + ' / ' + tokOut;
        document.getElementById('liveCO2').textContent = fmt(co2g, 2);
        document.getElementById('liveWh').textContent = fmt(wh, 2);
        document.getElementById('liveH2O').textContent = fmt(water, 1);
        document.getElementById('liveEq').textContent =
          kmCar < 1 ? fmt(kmCar * 1000, 0) + ' m' : fmt(kmCar, 1) + ' km';
        document.getElementById('liveMix').textContent = m.mix + ' g/kWh';
        document.getElementById('bignum').textContent = fmt(co2g, 2);
      }
      document.getElementById('liveInput').addEventListener('input', calcLive);
      document.getElementById('liveModel').addEventListener('change', calcLive);
      calcLive();

      /* Ch 3 — Usage tracker (interactive days) */
      document.querySelectorAll('#upChart .up-day').forEach((d) => {
        d.addEventListener('click', () => {
          document.querySelectorAll('#upChart .up-day').forEach((x) => x.classList.remove('on'));
          d.classList.add('on');
          document.getElementById('upDay').textContent = d.dataset.day;
          document.getElementById('upVal').textContent = d.dataset.val;
        });
      });

      /* Ch 4 — Datacenter dots interactive */
      const dcDetail = document.getElementById('dcDetail');
      document.querySelectorAll('#dcDots circle').forEach((c) => {
        c.style.cursor = 'pointer';
        c.style.transition = 'transform 200ms';
        c.addEventListener('mouseenter', () => {
          c.setAttribute('r', +c.getAttribute('r') + 2);
          const mix = +c.dataset.mix,
            pue = c.dataset.pue,
            sites = c.dataset.sites;
          const tone = mix < 100 ? 'var(--lime)' : mix < 250 ? '#f5b769' : '#f08c5a';
          dcDetail.innerHTML =
            '<div class="dc-title">' +
            c.dataset.dc +
            '</div>' +
            '<div class="dc-row"><span>Mix CO₂</span><b style="color:' +
            tone +
            '">' +
            mix +
            ' g/kWh</b></div>' +
            '<div class="dc-row"><span>PUE moyen</span><b>' +
            pue +
            '</b></div>' +
            '<div class="dc-row"><span>Sites recensés</span><b>' +
            sites +
            '</b></div>' +
            '<div class="dc-op">' +
            c.dataset.op +
            '</div>';
        });
        c.addEventListener('mouseleave', () => {
          c.setAttribute('r', +c.getAttribute('r') - 2);
        });
      });

      /* keep particle multiplier stable */
      window.__multiVal = 0;

      /* ─── Reveals ─── */
      const io = new IntersectionObserver(
        (es) =>
          es.forEach((e) => {
            if (e.isIntersecting) e.target.classList.add('lit');
          }),
        { threshold: 0.18 },
      );
      document.querySelectorAll('.rise').forEach((el) => io.observe(el));

      /* ─── Live typing demo (ch 5) ─── */
      const LIVE_TEXT =
        "La photosynthèse est le processus par lequel les plantes convertissent la lumière en énergie chimique. Elle se déroule dans les chloroplastes et libère de l'oxygène, essentiel à la vie.";
      const VALUES = ['0,42 g', '0,98 g', '1,54 g', '2,01 g', '2,14 g'];
      let typed = 0,
        started = false;
      function typeStep() {
        const resp = document.getElementById('resp');
        const val = document.getElementById('liveVal');
        if (!resp) return;
        typed = Math.min(LIVE_TEXT.length, typed + 2);
        resp.innerHTML = LIVE_TEXT.slice(0, typed) + '<span class="cur"></span>';
        const stage = Math.floor((typed / LIVE_TEXT.length) * VALUES.length);
        val.textContent = (VALUES[Math.min(stage, VALUES.length - 1)] || '2,14 g') + ' CO₂eq';
        if (typed < LIVE_TEXT.length) setTimeout(typeStep, 35 + Math.random() * 40);
        else
          setTimeout(() => {
            typed = 0;
            typeStep();
          }, 3000);
      }
      new IntersectionObserver(
        (es) =>
          es.forEach((e) => {
            if (e.isIntersecting && !started) {
              started = true;
              typeStep();
            }
          }),
        { threshold: 0.4 },
      ).observe(document.querySelector('.ch-5'));
    </script>
    <script is:inline>
      /* FR / EN translations (kept from handoff; only nav + headings mapped) */
      const I18N = {
        'La boîte à outils': { fr: 'La boîte à outils', en: 'The toolbox' },
        'Le chiffre invisible': { fr: 'Le chiffre invisible', en: 'The invisible number' },
        'Pour ton équipe': { fr: 'Pour ton équipe', en: 'For your team' },
        'Suivi personnel': { fr: 'Suivi personnel', en: 'Personal tracking' },
        'Recherche & datacenters': { fr: 'Recherche & datacenters', en: 'Research & datacenters' },
        'En direct dans ton chat': { fr: 'En direct dans ton chat', en: 'Live in your chat' },
        Maintenant: { fr: 'Maintenant', en: 'Now' },
        Installer: { fr: 'Installer', en: 'Install' },
        Produit: { fr: 'Produit', en: 'Product' },
        Cloud: { fr: 'Cloud', en: 'Cloud' },
        Télécharger: { fr: 'Télécharger', en: 'Download' },
        Docs: { fr: 'Docs', en: 'Docs' },
      };
      [
        '.kicker',
        '.huge',
        '.giant',
        '.large',
        '.body-l',
        '.btn',
        '.nav .links a',
        '.foot .col h4',
        '.foot .col a',
        'label',
        '.feat-list li b',
      ].forEach((sel) => {
        document.querySelectorAll(sel).forEach((el) => {
          if (!el.dataset.fr) el.dataset.fr = el.textContent.trim();
        });
      });

      function applyLang(lang) {
        document.querySelectorAll('[data-fr]').forEach((el) => {
          const fr = el.dataset.fr;
          const en = el.dataset.en || (I18N[fr] && I18N[fr].en) || fr;
          if (lang === 'en' && (el.dataset.en || I18N[fr])) {
            const textNode = [...el.childNodes].find((n) => n.nodeType === 3);
            if (textNode) textNode.nodeValue = en;
          } else {
            const textNode = [...el.childNodes].find((n) => n.nodeType === 3);
            if (textNode) textNode.nodeValue = fr;
          }
        });
      }
      document.querySelectorAll('.lang-toggle button').forEach((b) =>
        b.addEventListener('click', () => {
          document.querySelectorAll('.lang-toggle button').forEach((x) => x.classList.remove('on'));
          b.classList.add('on');
          applyLang(b.dataset.lang);
        }),
      );
    </script>
  </body>
</html>
