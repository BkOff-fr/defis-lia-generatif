      .tb-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
      }
      .tb-title {
        font: 500 11px var(--mono);
        color: var(--ivory-3);
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }
      .tb-export {
        font: 600 10px var(--ui);
