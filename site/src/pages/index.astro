        font: 500 10px var(--ui);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ivory-4);
      }
      .up-detail .v {
        font: 400 15px var(--display);
        font-style: italic;
        color: var(--ivory);
      }
      .up-detail .v b {
        color: var(--lime);
        font-style: italic;
        font-weight: 400;
      }
      .up-alerts {
