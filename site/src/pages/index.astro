      /* ─── ch-3 usage panel ─── */
      .usage-panel {
        background: linear-gradient(160deg, rgba(15, 18, 16, 0.92), rgba(15, 18, 16, 0.65));
        backdrop-filter: blur(20px);
        border: 1px solid rgba(197, 240, 74, 0.22);
        border-radius: 18px;
        padding: 22px;
        box-shadow:
          0 40px 100px rgba(0, 0, 0, 0.6),
          0 0 60px rgba(197, 240, 74, 0.05);
