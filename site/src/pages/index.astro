        border-radius: 8px;
      }
      .nav .links a.on {
        color: var(--lime);
      }
      .nav .grow {
        flex: 1;
      }
      .foot {
        padding: 60px 0 30px;
        border-top: 1px solid var(--border);
        position: relative;
        z-index: 10;
        background: rgba(10, 13, 11, 0.7);
        backdrop-filter: blur(10px);
      }
      .foot .inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 24px;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 36px;
      }
      .foot .col h4 {
        font: 500 11px var(--ui);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ivory-3);
        margin-bottom: 14px;
      }
      .foot .col a {
        display: block;
        padding: 4px 0;
        color: var(--ivory-2);
        font: 400 13px var(--ui);
        text-decoration: none;
      }
      .foot .col a:hover {
        color: var(--lime);
      }
      .foot .brand {
        font: 400 28px var(--display);
        font-style: italic;
        color: var(--ivory);
      }
      .foot .brand i {
        color: var(--lime);
      }
      .foot .tag {
        font: 400 13px/1.5 var(--ui);
        color: var(--ivory-3);
        font-style: italic;
        margin-top: 10px;
        max-width: 300px;
      }
      .foot .bottom {
        max-width: 1280px;
        margin: 30px auto 0;
        padding: 18px 24px 0;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        font: 400 11px var(--mono);
        color: var(--ivory-4);
      }

      .scroll-cue {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        font: 500 10px var(--mono);
        text-transform: uppercase;
        letter-spacing: 0.24em;
        color: var(--ivory-3);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        z-index: 20;
        opacity: 1;
        transition: opacity 500ms;
      }
      .scroll-cue.gone {
        opacity: 0;
      }
      .scroll-cue::after {
        content: '';
        width: 1px;
        height: 38px;
        background: linear-gradient(180deg, var(--lime), transparent);
        animation: drop 2.2s ease-in-out infinite;
      }
      @keyframes drop {
        0% {
          transform: translateY(-14px);
          opacity: 0;
        }
        40% {
          opacity: 1;
        }
        100% {
          transform: translateY(14px);
          opacity: 0;
        }
      }
    </style>
  </head>
  <body>
    <div class="stage">
      <canvas id="webgl"></canvas>
      <div class="grain"></div>
