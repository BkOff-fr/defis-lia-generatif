              </div>
              <select id="liveModel">
                <option value="gpt5">GPT-5 (US-East)</option>
                <option value="claude4">Claude 4 (US-West)</option>
                <option value="mistralL">Mistral Large (FR)</option>
                <option value="gpt4mini">GPT-4o-mini (US-East)</option>
              </select>
            </div>
            <div class="meters">
