                </svg>
              </div>
            </div>
            <div class="up-chart" id="upChart">
              <div class="up-day" data-day="Lundi" data-val="32">
                <i style="--h:64%"></i><span class="up-l">L</span>
              </div>
              <div class="up-day" data-day="Mardi" data-val="48">
                <i style="--h:96%"></i><span class="up-l">M</span>
              </div>
              <div class="up-day" data-day="Mercredi" data-val="22">
