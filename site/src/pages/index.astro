---
// C33.8 — Refonte home Sobr.ia (handoff bundle Anthropic Design).
//
// Page self-contained : @font-face vers /public/fonts/, CSS et JS inlines,
// Three.js charge via unpkg CDN. Pas de BaseLayout (la nav + footer du
// design sont integres). Les sections Hero / PourQui / CommentCaMarche /
// Methodologies / VendorDisclosure / TerritoireFR / Entreprises issues de
// C33.3-C33.5 restent disponibles dans src/components/sections/ pour
// reusage sur d'autres routes ; git pre-C33.8 conserve l'index v1.
//
// Source design : sobr-ia-design-system/project/site/index.html (handoff
// 2026-05-12 via claude.ai/design). Adaptations apportees :
//   - hrefs index.html / cloud.html / download.html / docs.html mappes
//     vers les routes Astro (/, /cloud, /telecharger, /docs/).
//   - @font-face inline pointant vers /fonts/*.woff2 (deja auto-heberges
//     pour C33.4).
//   - terrainMat + metaballs (references mortes dans la JS d'origine)
//     supprimes pour eviter ReferenceError en runtime.

const canonical = new URL('/', Astro.site).href;
const ogImage = new URL('/og-image.png', Astro.site).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Sobr.ia — Le poids invisible de tes prompts</title>
    <meta
      name="description"
      content="Mesure, suis, arbitre l'empreinte de tes prompts IA. Extension navigateur, dashboard d'équipe, suivi personnel, carte des datacenters européens. 100 % local, open source."
    />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content="Sobr.ia — Le poids invisible de tes prompts" />
    <meta
      property="og:description"
      content="Extension navigateur, dashboard d'équipe, suivi personnel, carte des datacenters européens. Sobr.ia est l'outil ouvert pour quantifier — et réduire — l'empreinte de l'IA générative."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Sobr.ia" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Sobr.ia — Le poids invisible de tes prompts" />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#0a0d0b" />

    <style is:inline>
      /* ─── Fonts auto-hebergees (cf. C33.4) ──────────────────────────── */
      @font-face {
        font-family: 'Geist';
        font-style: normal;
        font-weight: 300 700;
        font-display: swap;
        src: url('/fonts/geist-latin.woff2') format('woff2');
      }
      @font-face {
        font-family: 'Geist';
        font-style: normal;
        font-weight: 300 700;
        font-display: swap;
        src: url('/fonts/geist-latin-ext.woff2') format('woff2');
      }
      @font-face {
        font-family: 'Instrument Serif';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/instrument-serif-latin.woff2') format('woff2');
      }
      @font-face {
        font-family: 'Instrument Serif';
        font-style: italic;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/instrument-serif-italic-latin.woff2') format('woff2');
      }
      @font-face {
        font-family: 'JetBrains Mono';
        font-style: normal;
        font-weight: 400 600;
        font-display: swap;
        src: url('/fonts/jetbrains-mono-latin.woff2') format('woff2');
      }

      /* ─── Reset + base ──────────────────────────────────────────────── */
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        background: #0a0d0b;
        color: #f0ece3;
        font-family: 'Geist', system-ui, sans-serif;
        overflow-x: hidden;
      }
      :root {
        --ink: #0a0d0b;
        --lime: #c5f04a;
        --ivory: #f0ece3;
        --ivory-2: #b8b4ac;
        --ivory-3: #72706a;
        --ivory-4: #46443f;
        --border: rgba(255, 255, 255, 0.07);
        --display: 'Instrument Serif', serif;
        --mono: 'JetBrains Mono', monospace;
        --ui: 'Geist', system-ui, sans-serif;
      }

      /* Persistent stage */
      .stage {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
      }
      .stage canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        z-index: 3;
      }
      .stage .grain {
        position: absolute;
        inset: 0;
        z-index: 4;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 .77, 0 0 0 0 .94, 0 0 0 0 .29, 0 0 0 .04 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
        opacity: 0.4;
        mix-blend-mode: overlay;
        pointer-events: none;
      }
      .stage .vignette {
        position: absolute;
        inset: 0;
        z-index: 5;
        background: radial-gradient(ellipse at center, transparent 40%, rgba(10, 13, 11, 0.6) 100%);
        pointer-events: none;
      }

      .progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 2px;
        width: 0;
        background: linear-gradient(90deg, #7a9a32, var(--lime));
        z-index: 200;
        box-shadow: 0 0 12px var(--lime);
        transition: width 120ms linear;
      }
      .rail {
        position: fixed;
        right: 22px;
        top: 50%;
        transform: translateY(-50%);
        z-index: 150;
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .rail .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.18);
        cursor: pointer;
        position: relative;
        transition: all 300ms;
      }
      .rail .dot.on {
        background: var(--lime);
        box-shadow: 0 0 14px var(--lime);
        transform: scale(1.5);
      }
      .rail .dot .lab {
        position: absolute;
        right: 18px;
        top: 50%;
        transform: translateY(-50%);
        font: 500 9px var(--mono);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--ivory-3);
        background: rgba(10, 13, 11, 0.9);
        backdrop-filter: blur(8px);
        padding: 4px 10px;
        border-radius: 99px;
        border: 1px solid var(--border);
        opacity: 0;
        transition: opacity 200ms;
        white-space: nowrap;
        pointer-events: none;
      }
      .rail .dot:hover .lab,
      .rail .dot.on .lab {
        opacity: 1;
      }
      @media (max-width: 900px) {
        .rail {
          display: none;
        }
      }

      .layer {
        position: relative;
        z-index: 10;
      }
      .chap {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 96px 24px 60px;
      }
      .chap .inner {
        max-width: 1280px;
        margin: 0 auto;
        width: 100%;
      }

      .kicker {
        font: 500 11px var(--ui);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--lime);
        display: inline-flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 24px;
      }
      .kicker::before {
        content: '';
        width: 32px;
        height: 1px;
        background: var(--lime);
      }
      .kicker .num {
        font: 400 13px var(--mono);
        color: var(--ivory-3);
      }
      .giant {
        font: 400 clamp(48px, 9vw, 128px)/0.95 var(--display);
        font-style: italic;
        letter-spacing: -0.025em;
        color: var(--ivory);
        text-wrap: balance;
        max-width: 1100px;
      }
      .giant i {
        color: var(--lime);
      }
      .huge {
        font: 400 clamp(40px, 7vw, 104px)/1 var(--display);
        font-style: italic;
        letter-spacing: -0.025em;
        color: var(--ivory);
        max-width: 1100px;
      }
      .huge i {
        color: var(--lime);
      }
      .large {
        font: 400 clamp(28px, 4.5vw, 64px)/1.05 var(--display);
        font-style: italic;
        letter-spacing: -0.02em;
        color: var(--ivory);
        max-width: 900px;
      }
      .large i {
        color: var(--lime);
      }
      .body-l {
        font: 400 clamp(14px, 1.2vw, 18px)/1.65 var(--ui);
        color: var(--ivory-2);
        max-width: 520px;
      }
      .body-l b {
        color: var(--ivory);
        font-weight: 500;
      }

      .rise {
        opacity: 0;
        transform: translateY(36px);
        transition:
          opacity 900ms cubic-bezier(0.2, 0.8, 0.2, 1),
          transform 900ms cubic-bezier(0.2, 0.8, 0.2, 1);
      }
      .rise.lit {
        opacity: 1;
        transform: translateY(0);
      }
      .rise.d1 {
        transition-delay: 140ms;
      }
      .rise.d2 {
        transition-delay: 280ms;
      }
      .rise.d3 {
        transition-delay: 420ms;
      }

      /* FR/EN lang toggle in nav */
      .lang-toggle {
        display: inline-flex;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 99px;
        padding: 3px;
        margin-left: 8px;
      }
      .lang-toggle button {
        background: transparent;
        border: none;
        color: #72706a;
        font: 600 10px var(--ui);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        padding: 6px 10px;
        border-radius: 99px;
        cursor: pointer;
        transition: all 200ms;
      }
      .lang-toggle button.on {
        background: #c5f04a;
        color: #0a0d0b;
      }
      .lang-toggle button:not(.on):hover {
        color: #f0ece3;
      }

      /* Mobile bottom rail */
      @media (max-width: 900px) {
        .rail {
          display: flex !important;
          flex-direction: row;
          right: auto;
          top: auto;
          left: 50%;
          bottom: 18px;
          transform: translateX(-50%);
          background: rgba(10, 13, 11, 0.85);
          backdrop-filter: blur(16px);
          border: 1px solid rgba(255, 255, 255, 0.07);
          padding: 10px 14px;
          border-radius: 99px;
          gap: 10px;
          z-index: 160;
        }
        .rail .dot {
          width: 8px;
          height: 8px;
        }
        .rail .dot .lab {
          display: none;
        }
        .scroll-cue {
          bottom: 74px;
        }
        .nav .links a:not(:first-child):not(:last-child) {
          display: none;
        }
        .lang-toggle {
          display: none;
        }
      }

      /* Layout normalisation */
      .chap {
        padding: 120px 24px;
      }
      .chap .inner {
        max-width: 1240px;
        margin: 0 auto;
        width: 100%;
      }
      .ch-0 .inner,
      .ch-4 .inner,
      .ch-6 .inner {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 20px;
      }
      .ch-0 .inner > div,
      .ch-4 .inner > div,
      .ch-6 .inner > div {
        max-width: 880px;
        margin: 0 auto;
      }
      .ch-0 .giant,
      .ch-4 .huge,
      .ch-6 .huge {
        margin-left: auto;
        margin-right: auto;
      }
      .ch-0 .body-l,
      .ch-4 .body-l,
      .ch-6 .body-l {
        margin-left: auto;
        margin-right: auto;
      }
      .ch-1 .inner,
      .ch-2 .inner,
      .ch-3 .inner,
      .ch-5 .inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 64px;
        align-items: center;
      }
      .ch-2 .inner {
        grid-template-columns: 1fr 1.1fr;
      }
      .ch-3 .inner {
        grid-template-columns: 1.1fr 1fr;
      }
      .chap .kicker {
        margin-bottom: 24px;
      }
      .chap .huge,
      .chap .giant {
        margin-bottom: 24px;
      }
      .chap .body-l {
        margin-bottom: 0;
      }
      .chap .body-l + .body-l {
        margin-top: 18px;
      }
      @media (max-width: 1000px) {
        .ch-1 .inner,
        .ch-2 .inner,
        .ch-3 .inner,
        .ch-5 .inner {
          grid-template-columns: 1fr;
          text-align: left;
          gap: 48px;
        }
      }
      @media (max-width: 700px) {
        .chap {
          padding: 88px 22px;
        }
      }

      /* ─── INTERACTIVE PROMPT BOX (ch 1) ─── */
      .prompt-lab {
        background: linear-gradient(160deg, rgba(15, 18, 16, 0.85), rgba(15, 18, 16, 0.45));
        backdrop-filter: blur(22px);
        border: 1px solid rgba(197, 240, 74, 0.25);
        border-radius: 18px;
        padding: 24px;
        box-shadow:
          0 40px 120px rgba(0, 0, 0, 0.6),
          0 0 60px rgba(197, 240, 74, 0.06);
      }
      .prompt-lab .top {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 14px;
        font: 500 10px var(--mono);
        color: var(--ivory-3);
        text-transform: uppercase;
        letter-spacing: 0.14em;
      }
      .prompt-lab .top .led {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--lime);
        box-shadow: 0 0 12px var(--lime);
        animation: livePulse 1.6s ease-in-out infinite;
      }
      @keyframes livePulse {
        0%,
        100% {
          opacity: 0.5;
        }
        50% {
          opacity: 1;
        }
      }
      .prompt-lab label {
        display: block;
        font: 500 10px var(--ui);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ivory-3);
        margin-bottom: 8px;
      }
      .prompt-lab textarea {
        width: 100%;
        min-height: 88px;
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 14px 16px;
        font: 400 15px/1.55 var(--ui);
        color: var(--ivory);
        outline: none;
        resize: vertical;
        transition: border-color 200ms;
      }
      .prompt-lab textarea:focus {
        border-color: rgba(197, 240, 74, 0.45);
      }
      .prompt-lab .row {
        display: flex;
        gap: 10px;
        margin-top: 14px;
        align-items: center;
      }
      .prompt-lab .model {
        flex: 1;
        font: 400 12px var(--mono);
        color: var(--ivory-3);
      }
      .prompt-lab select {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 6px 10px;
        color: var(--ivory);
        font: 500 11px var(--ui);
        outline: none;
        cursor: pointer;
      }
      .prompt-lab .meters {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-top: 18px;
        padding-top: 14px;
        border-top: 1px dashed var(--border);
      }
      .prompt-lab .meter {
        background: rgba(255, 255, 255, 0.02);
        border: 1px dashed var(--border);
        border-radius: 10px;
        padding: 10px 12px;
      }
      .prompt-lab .meter .k {
        font: 500 9px var(--ui);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ivory-4);
      }
      .prompt-lab .meter .v {
        font: 400 26px/1 var(--display);
        font-style: italic;
        color: var(--lime);
        margin-top: 4px;
        letter-spacing: -0.01em;
      }
      .prompt-lab .meter .v .u {
        font: 400 10px var(--ui);
        font-style: normal;
        color: var(--ivory-3);
        margin-left: 3px;
      }
      .prompt-lab .equiv {
        margin-top: 14px;
        padding: 12px 14px;
        background: rgba(126, 182, 255, 0.05);
        border: 1px dashed rgba(126, 182, 255, 0.22);
        border-radius: 10px;
        font: 400 12px/1.55 var(--ui);
        color: var(--ivory-2);
        font-style: italic;
      }
      .prompt-lab .equiv b {
        color: var(--lime);
        font-style: normal;
        font-weight: 500;
      }

      .ch-1-bignum {
        position: absolute;
        font: 400 clamp(160px, 28vw, 420px)/0.85 var(--display);
        font-style: italic;
        letter-spacing: -0.04em;
        color: rgba(197, 240, 74, 0.1);
        pointer-events: none;
        user-select: none;
        left: 8%;
        top: 10%;
        text-shadow: 0 0 90px rgba(197, 240, 74, 0.18);
        z-index: 5;
      }

      /* CH 5 — live demo */
      .live-card {
        background: linear-gradient(160deg, rgba(15, 18, 16, 0.95), rgba(15, 18, 16, 0.78));
        backdrop-filter: blur(18px);
        border: 1px solid rgba(197, 240, 74, 0.2);
        border-radius: 18px;
        padding: 20px;
        box-shadow:
          0 40px 100px rgba(0, 0, 0, 0.65),
          0 0 80px rgba(197, 240, 74, 0.08);
        max-width: 540px;
      }
      .live-card .top {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 14px;
        font: 500 10px var(--mono);
        color: var(--ivory-3);
        text-transform: uppercase;
        letter-spacing: 0.14em;
      }
      .live-card .led {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--lime);
        box-shadow: 0 0 12px var(--lime);
        animation: livePulse 1.6s ease-in-out infinite;
      }
      .live-card .prompt {
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 14px 16px;
        font: 400 14px/1.55 var(--ui);
        color: var(--ivory-2);
        margin-bottom: 14px;
      }
      .live-card .prompt::before {
        content: '> ';
        color: var(--lime);
        font-family: var(--mono);
      }
      .live-card .response {
        padding: 14px 16px;
        background: rgba(126, 182, 255, 0.04);
        border-left: 2px solid #7eb6ff;
        border-radius: 0 8px 8px 0;
        font: 400 13px/1.6 var(--ui);
        color: var(--ivory-2);
        margin-bottom: 14px;
        min-height: 80px;
      }
      .live-card .response .cur {
        display: inline-block;
        width: 7px;
        height: 1em;
        background: var(--lime);
        margin-left: 2px;
        vertical-align: -2px;
        animation: bl 1s steps(2) infinite;
      }
      @keyframes bl {
        50% {
          opacity: 0;
        }
      }
      .live-card .badge-row {
        display: flex;
        justify-content: flex-end;
        padding-top: 10px;
        border-top: 1px dashed var(--border);
      }
      .sb-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        background: rgba(197, 240, 74, 0.08);
        border: 1px solid rgba(197, 240, 74, 0.32);
        border-radius: 99px;
        color: var(--lime);
        font: 500 12px var(--ui);
      }
      .sb-badge .v {
        font-family: var(--mono);
      }
      .sb-badge .by {
        font: 400 9px var(--ui);
        color: rgba(197, 240, 74, 0.55);
        padding-left: 7px;
        border-left: 1px solid rgba(197, 240, 74, 0.25);
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      /* CH 6 actions */
      .ch-6 .actions {
        display: flex;
        justify-content: center;
        gap: 14px;
        margin-top: 5vh;
        flex-wrap: wrap;
      }
      .ch-6 .meta {
        margin-top: 6vh;
        font: 400 12px var(--mono);
        color: var(--ivory-3);
        display: inline-flex;
        align-items: center;
        gap: 18px;
        padding: 10px 22px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px dashed var(--border);
        border-radius: 99px;
        flex-wrap: wrap;
        justify-content: center;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 13px 22px;
        border-radius: 99px;
        font: 600 13px var(--ui);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        cursor: pointer;
        border: none;
        text-decoration: none;
        transition: all 250ms;
      }
      .btn.primary {
        background: var(--lime);
        color: var(--ink);
      }
      .btn.primary:hover {
        box-shadow: 0 0 32px rgba(197, 240, 74, 0.45);
        transform: translateY(-1px);
      }
      .btn.ghost {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--ivory);
      }
      .btn.ghost:hover {
        border-color: var(--lime);
        color: var(--lime);
      }

      /* ─── ch-0 hero feats ─── */
      .hero-feats {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        font: 500 11px var(--mono);
        color: var(--ivory-3);
        text-transform: uppercase;
        letter-spacing: 0.12em;
      }
      .hero-feats span:not(:nth-child(even)) {
        color: var(--lime);
      }

      /* ─── shared feat-list ─── */
      .feat-list {
        list-style: none;
        padding: 0;
        margin: 24px 0 0;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .feat-list li {
        font: 400 14px/1.5 var(--ui);
        color: var(--ivory-2);
        padding-left: 22px;
        position: relative;
      }
      .feat-list li::before {
        content: '';
        position: absolute;
        left: 0;
        top: 10px;
        width: 12px;
        height: 1px;
        background: var(--lime);
      }
