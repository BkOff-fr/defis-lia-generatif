      }
      .tb-stat .v small {
        font: 400 10px var(--ui);
        font-style: normal;
        color: var(--ivory-3);
        margin-left: 4px;
      }
      .tb-rows {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .tb-row {
        display: grid;
        grid-template-columns: 30px 1fr 100px 64px;
        align-items: center;
        gap: 10px;
        padding: 7px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
