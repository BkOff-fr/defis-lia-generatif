---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '$components/sections/Hero.astro';
import PourQui from '$components/sections/PourQui.astro';
import CommentCaMarche from '$components/sections/CommentCaMarche.astro';
import DownloadSection from '$components/sections/DownloadSection.svelte';
import Methodologies from '$components/sections/Methodologies.astro';
import VendorDisclosure from '$components/sections/VendorDisclosure.astro';
import TerritoireFR from '$components/sections/TerritoireFR.astro';
import Entreprises from '$components/sections/Entreprises.astro';
---

<BaseLayout
  title="Sobr.ia — l'empreinte de vos prompts IA, mesurée"
  description="Application native multi-plateforme qui mesure l'empreinte carbone, eau, énergie de chaque prompt LLM. Frugal, open source, candidat défi data.gouv.fr."
>
  <Hero />
  <PourQui />
  <CommentCaMarche />

  <DownloadSection client:visible />

  <Methodologies />
  <VendorDisclosure />
  <TerritoireFR />
  <Entreprises />
</BaseLayout>
