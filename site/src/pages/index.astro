      .up-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
      }
      .up-title {
        font: 500 13px var(--ui);
        color: var(--ivory);
      }
      .up-title b {
        color: var(--lime);
        font-weight: 500;
      }
      .up-sub {
        font: 400 11px var(--mono);
        color: var(--ivory-3);
