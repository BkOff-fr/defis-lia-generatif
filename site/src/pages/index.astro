      }
      @media (max-width: 900px) {
        .dc-map {
          grid-template-columns: 1fr;
        }
      }

      /* nav + footer */
      .nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: rgba(10, 13, 11, 0.45);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
      }
      .nav .inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 14px 24px;
        display: flex;
        align-items: center;
        gap: 24px;
      }
      .nav .logo {
        display: flex;
        align-items: center;
        gap: 9px;
        font: 400 18px var(--display);
        font-style: italic;
        color: var(--ivory);
        text-decoration: none;
      }
      .nav .logo i {
        color: var(--lime);
      }
      .nav .links {
        display: flex;
        gap: 6px;
      }
      .nav .links a {
        padding: 8px 12px;
        color: var(--ivory-3);
        font: 500 12px var(--ui);
