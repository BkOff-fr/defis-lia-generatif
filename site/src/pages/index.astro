        padding: 14px 16px;
        font: 400 12px var(--ui);
        color: var(--ivory-2);
      }
      .dc-title {
        font: 400 17px var(--display);
        font-style: italic;
        color: var(--ivory);
        margin-bottom: 6px;
        letter-spacing: -0.01em;
