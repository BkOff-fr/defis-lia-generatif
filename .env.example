# Variables d'environnement Sobr.ia — copier en .env (jamais committé).
# Voir CLAUDE.md §7 (sécurité).

# Méthodologie (ADR-0004) — seed Monte-Carlo pour reproductibilité.
SOBRIA_SEED=42

# Tier 3 optionnel : RTE eco2mix live (compte gratuit).
# Sans ces clés, Sobr.ia utilise les CSV historiques RTE — fonctionne quand même.
# RTE_CLIENT_ID=
# RTE_CLIENT_SECRET=

# DVC remote (S3-compatible : Cloudflare R2 recommandé).
# DVC_REMOTE_URL=s3://sobria-data
# DVC_REMOTE_KEY=
# DVC_REMOTE_SECRET=

# Logging
RUST_LOG=info,sobria=debug
